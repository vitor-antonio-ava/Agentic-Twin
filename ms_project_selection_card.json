{
  type: "AdaptiveCard",
  '$schema': "http://adaptivecards.io/schemas/adaptive-card.json",
  version: "1.5",
  body: [
    {
      type: "Container",
      style: "emphasis",
      bleed: true,
      items: [
        {
          type: "ColumnSet",
          columns: [
            {
              type: "Column",
              width: "auto",
              items: [
                {
                  type: "Image",
                  url: "https://img.icons8.com/fluency/48/project-management.png",
                  size: "Small"
                }
              ]
            },
            {
              type: "Column",
              width: "stretch",
              verticalContentAlignment: "Center",
              items: [
                {
                  type: "TextBlock",
                  text: "MS Project Selection",
                  size: "Large",
                  weight: "Bolder",
                  color: "Accent"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      type: "TextBlock",
      text: "Search and select the MS Projects you want to associate. You can select multiple projects.",
      wrap: true,
      spacing: "Medium"
    },
    {
      type: "TextBlock",
      text: "Search by project name or owner:",
      weight: "Bolder",
      spacing: "Medium"
    },
    {
      type: "Input.ChoiceSet",
      id: "selectedProjects",
      style: "filtered",
      isMultiSelect: true,
      placeholder: "Type to search projects...",
      choices: ForAll(
        ParseJSON(Topic.msProjectsList),
        {
          title: Text(ThisRecord.'FCT_ACTIVE_MS_PROJECTS[ProjectName]') & " (" & Text(ThisRecord.'FCT_ACTIVE_MS_PROJECTS[Owner]') & ")",
          value: Text(ThisRecord.'FCT_ACTIVE_MS_PROJECTS[ProjectId]')
        }
      )
    },
    {
      type: "TextBlock",
      text: "💡 Tip: Type a project name or owner to filter the list",
      size: "Small",
      isSubtle: true,
      spacing: "Small"
    },
    {
      type: "ActionSet",
      actions: [
        { type: "Action.Submit", id: "submitProjectSelection", title: "✓ Confirm Selection", style: "positive" },
        { type: "Action.Submit", id: "skipProjectSelection", title: "Skip", style: "destructive" }
      ]
    }
  ]
}
